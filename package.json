{
  "name": "anaxi-learn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts",
    "db:import:unit1-first25": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/import-unit1-first25.ts",
    "db:import:unit1-next25": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/import-unit1-next25.ts",
    "db:import:unit1-n14": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/import-unit1-n14.ts",
    "db:import:unit1-gapfill-n11-n12-n15": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/import-unit1-gapfill-n11-n12-n15.ts",
    "db:import:unit1-gapfill-n14": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/import-unit1-gapfill-n14.ts",
    "db:ensure:routes:n14-n15": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/ensure-routes-n14-n15.ts",
    "db:normalize:step-question-types": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/normalize-explanation-step-question-types.ts",
    "db:normalize:item-routing-purpose": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/normalize-item-routing-purpose.ts",
    "db:import:unit1-all": "npm run db:import:unit1-first25 && npm run db:import:unit1-next25 && npm run db:import:unit1-n14 && npm run db:import:unit1-gapfill-n11-n12-n15 && npm run db:import:unit1-gapfill-n14 && npm run db:ensure:routes:n14-n15 && npm run db:normalize:step-question-types",
    "validate:learning": "node scripts/validate-learning-config.mjs",
    "validate:items": "node scripts/validate-item-answer-types.mjs",
    "validate:explanation-steps": "node scripts/validate-explanations.mjs",
    "validate:n13": "node scripts/validate-n13-content-integrity.mjs",
    "validate:explanations": "node scripts/validate-explanation-integrity.mjs",
    "validate:qa": "npm run validate:items && npm run validate:n13 && npm run validate:explanation-steps && npm run validate:explanations && npm test",
    "content:extract:unit1": "node scripts/extract-curriculum-pptx.mjs",
    "content:report:unit1-gaps": "node scripts/report-curriculum-seeding-gaps.mjs",
    "content:build:unit1-packs": "node scripts/build-curriculum-review-packs.mjs",
    "content:build:phase1-queue": "node scripts/build-phase1-authoring-queue.mjs",
    "content:build:phase1-briefs": "node scripts/build-phase1-author-briefs.mjs"
  },
  "prisma": {
    "seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts && ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/ensure-routes-n14-n15.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "next": "^15.5.12",
    "next-auth": "^4.24.13",
    "react": "^18",
    "react-dom": "^18",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^15.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.3",
    "jsdom": "^24.0.0",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^1.5.0"
  }
}
