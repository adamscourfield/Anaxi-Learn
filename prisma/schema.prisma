generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String?
  role          Role           @default(STUDENT)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  attempts      Attempt[]
  skillMasteries SkillMastery[]
  events        Event[]
}

model Subject {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  skills      Skill[]
  events      Event[]
}

model Skill {
  id            String         @id @default(cuid())
  name          String
  slug          String
  description   String?
  intro         String?
  subjectId     String
  createdAt     DateTime       @default(now())
  subject       Subject        @relation(fields: [subjectId], references: [id])
  prerequisites SkillPrereq[]  @relation("SkillToPrereq")
  dependents    SkillPrereq[]  @relation("PrereqToSkill")
  items         ItemSkill[]
  masteries     SkillMastery[]
  events        Event[]

  @@unique([subjectId, slug])
}

model SkillPrereq {
  skillId    String
  prereqId   String
  skill      Skill  @relation("SkillToPrereq", fields: [skillId], references: [id])
  prereq     Skill  @relation("PrereqToSkill", fields: [prereqId], references: [id])

  @@id([skillId, prereqId])
}

model Item {
  id        String      @id @default(cuid())
  question  String
  type      String      @default("MCQ")
  options   Json
  answer    String
  createdAt DateTime    @default(now())
  skills    ItemSkill[]
  attempts  Attempt[]
  events    Event[]
}

model ItemSkill {
  itemId    String
  skillId   String
  item      Item   @relation(fields: [itemId], references: [id])
  skill     Skill  @relation(fields: [skillId], references: [id])

  @@id([itemId, skillId])
}

model Attempt {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  answer    String
  correct   Boolean
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  item      Item     @relation(fields: [itemId], references: [id])
  events    Event[]
}

model SkillMastery {
  id               String    @id @default(cuid())
  userId           String
  skillId          String
  mastery          Float     @default(0)
  lastPracticedAt  DateTime?
  nextReviewAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id])
  skill            Skill     @relation(fields: [skillId], references: [id])

  @@unique([userId, skillId])
}

model Event {
  id            String    @id @default(cuid())
  name          String
  actorUserId   String?
  studentUserId String?
  subjectId     String?
  skillId       String?
  itemId        String?
  attemptId     String?
  payload       Json
  createdAt     DateTime  @default(now())
  actor         User?     @relation(fields: [actorUserId], references: [id])
  subject       Subject?  @relation(fields: [subjectId], references: [id])
  skill         Skill?    @relation(fields: [skillId], references: [id])
  item          Item?     @relation(fields: [itemId], references: [id])
  attempt       Attempt?  @relation(fields: [attemptId], references: [id])
}
