generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum AttemptMode {
  PRACTICE
  DIAGNOSTIC
  REVIEW
}

enum DiagnosticStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum BaselineStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum KnowledgeQuestionType {
  ROUTINE
  FLUENCY
  RETRIEVAL
  TRANSFER
  APPLICATION
  MIXED
  DIAGNOSTIC
}

enum SupportLevel {
  INDEPENDENT
  LIGHT_PROMPT
  WORKED_EXAMPLE
  SCAFFOLDED
  FULL_EXPLANATION
}

enum QuestionContextType {
  ROUTINE
  MIXED
  TRANSFER
}

enum DelayBucket {
  IMMEDIATE
  SAME_DAY
  D1
  D3
  D7_PLUS
}

enum DurabilityBand {
  AT_RISK
  DEVELOPING
  DURABLE
}

enum LiveSessionStatus {
  LOBBY
  ACTIVE
  PAUSED
  COMPLETED
}

enum ItemReviewStatus {
  OPEN
  RESOLVED
}

enum ItemReviewCategory {
  ANSWER_MODE
  ANSWER_MAPPING
  STEM_COPY
  DISTRACTOR_QUALITY
  SKILL_MAPPING
  OTHER
}

model User {
  id                 String                  @id @default(cuid())
  email              String                  @unique
  password           String
  name               String?
  role               Role                    @default(STUDENT)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  attempts           Attempt[]
  baselineAttempts   BaselineAttempt[]
  skillMasteries     SkillMastery[]
  events             Event[]
  diagnosticSessions DiagnosticSession[]
  baselineSessions   BaselineSession[]
  interventionFlags  InterventionFlag[]
  teacherProfile     TeacherProfile?
  studentProfile     StudentProfile?
  classEnrollments       ClassroomEnrollment[]
  rewardBalance          StudentRewardBalance?
  rewardTransactions     RewardTransaction[]
  guessingSafeguard      GuessingSafeguardState?
  knowledgeSkillStates   StudentSkillState[]
  knowledgeQuestionAttempts QuestionAttempt[]
  knowledgeSkillReviews  SkillReview[]
  itemReviewNotes        ItemReviewNote[]       @relation("ItemReviewAuthor")
  teacherLiveSessions    LiveSession[]          @relation("TeacherLiveSessions")
  liveParticipants       LiveParticipant[]
  liveAttempts           LiveAttempt[]
}

model Subject {
  id                 String              @id @default(cuid())
  title              String
  slug               String              @unique
  description        String?
  createdAt          DateTime            @default(now())
  skills             Skill[]
  items              Item[]
  events             Event[]
  diagnosticSessions DiagnosticSession[]
  baselineSessions   BaselineSession[]
  interventionFlags  InterventionFlag[]
  rewardTransactions RewardTransaction[]
  liveSessions       LiveSession[]
}

model Skill {
  id                String             @id @default(cuid())
  code              String
  name              String
  slug              String
  strand            String             @default("")
  isStretch         Boolean            @default(false)
  sortOrder         Int                @default(0)
  description       String?
  intro             String?
  subjectId         String
  createdAt         DateTime           @default(now())
  subject           Subject            @relation(fields: [subjectId], references: [id])
  prerequisites     SkillPrereq[]      @relation("SkillToPrereq")
  dependents        SkillPrereq[]      @relation("PrereqToSkill")
  items             ItemSkill[]
  masteries         SkillMastery[]
  events            Event[]
  baselineAttempts         BaselineAttempt[]
  interventionFlags        InterventionFlag[]
  explanationRoutes        ExplanationRoute[]
  knowledgeSkillStates     StudentSkillState[]
  knowledgeQuestionAttempts QuestionAttempt[]
  knowledgeSkillReviews    SkillReview[]
  explanationPerformance   ExplanationPerformance[]
  liveSessions             LiveSession[]
  liveAttempts             LiveAttempt[]

  @@unique([subjectId, slug])
  @@unique([subjectId, code])
}

model SkillPrereq {
  skillId  String
  prereqId String
  weight   Int    @default(1)
  skill    Skill  @relation("SkillToPrereq", fields: [skillId], references: [id])
  prereq   Skill  @relation("PrereqToSkill", fields: [prereqId], references: [id])

  @@id([skillId, prereqId])
}

model Item {
  id               String            @id @default(cuid())
  question         String
  type             String            @default("MCQ")
  options          Json
  answer           String
  misconceptionMap Json?
  subjectId        String?
  createdAt        DateTime          @default(now())
  subject          Subject?          @relation(fields: [subjectId], references: [id])
  skills           ItemSkill[]
  attempts                  Attempt[]
  baselineAttempts          BaselineAttempt[]
  events                    Event[]
  knowledgeQuestionAttempts QuestionAttempt[]
  reviewNotes               ItemReviewNote[]
  liveAttempts              LiveAttempt[]
}

model ItemReviewNote {
  id           String             @id @default(cuid())
  itemId        String
  authorUserId  String
  status        ItemReviewStatus  @default(OPEN)
  category      ItemReviewCategory
  note          String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  resolvedAt    DateTime?
  item          Item              @relation(fields: [itemId], references: [id], onDelete: Cascade)
  author        User              @relation("ItemReviewAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([itemId, status, createdAt])
  @@index([authorUserId, createdAt])
}

model ItemSkill {
  itemId  String
  skillId String
  item    Item   @relation(fields: [itemId], references: [id])
  skill   Skill  @relation(fields: [skillId], references: [id])

  @@id([itemId, skillId])
}

model Attempt {
  id                String             @id @default(cuid())
  userId            String
  itemId            String
  answer            String
  correct           Boolean
  sessionId         String?
  mode              AttemptMode        @default(PRACTICE)
  createdAt         DateTime           @default(now())
  user              User               @relation(fields: [userId], references: [id])
  item              Item               @relation(fields: [itemId], references: [id])
  events            Event[]
  diagnosticSession DiagnosticSession? @relation("DiagnosticAttempts", fields: [sessionId], references: [id])
}

model SkillMastery {
  id                   String    @id @default(cuid())
  userId               String
  skillId              String
  mastery              Float     @default(0)
  streak               Int       @default(0)
  confirmedCount       Int       @default(0)
  lastPracticedAt      DateTime?
  nextReviewAt         DateTime?
  lastReviewedAt       DateTime?
  attemptsSinceConfirm Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id])
  skill                Skill     @relation(fields: [skillId], references: [id])

  @@unique([userId, skillId])
}

model StudentSkillState {
  id                      String         @id @default(cuid())
  userId                  String
  skillId                 String
  masteryProbability      Float          @default(0.35)
  forgettingRate          Float          @default(0.12)
  halfLifeDays            Float          @default(5.776226504666211)
  retrievalStrength       Float          @default(0.3)
  transferAbility         Float          @default(0.2)
  confidence              Float          @default(0.1)
  latestDle               Float?
  latestLearningGain      Float?
  latestKnowledgeStability Float?
  latestInstructionalTimeMs Int?
  durabilityBand          DurabilityBand @default(AT_RISK)
  lastAttemptAt           DateTime?
  lastSuccessAt           DateTime?
  lastReviewAt            DateTime?
  evidenceCount           Int            @default(0)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  user                    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill                   Skill          @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@index([skillId])
}

model QuestionAttempt {
  id                 String                @id @default(cuid())
  userId             String
  skillId            String
  itemId             String
  occurredAt         DateTime              @default(now())
  correct            Boolean
  responseTimeMs     Int
  hintsUsed          Int                   @default(0)
  explanationId      String?
  attemptNumber      Int                   @default(1)
  questionDifficulty Float                 @default(0.5)
  questionType       KnowledgeQuestionType @default(ROUTINE)
  contextType        QuestionContextType   @default(ROUTINE)
  delayBucket        DelayBucket           @default(IMMEDIATE)
  instructionalTimeMs Int                  @default(0)
  isTransferItem     Boolean               @default(false)
  isMixedItem        Boolean               @default(false)
  isReviewItem       Boolean               @default(false)
  supportLevel       SupportLevel          @default(INDEPENDENT)
  createdAt          DateTime              @default(now())
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill              Skill                 @relation(fields: [skillId], references: [id], onDelete: Cascade)
  item               Item                  @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([userId, skillId, occurredAt])
  @@index([skillId, occurredAt])
}

model SkillReview {
  id                    String    @id @default(cuid())
  userId                String
  skillId               String
  scheduledFor          DateTime
  completedAt           DateTime?
  successScore          Float?
  daysSinceLastExposure Float?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill                 Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([userId, scheduledFor])
  @@index([userId, skillId, scheduledFor])
}

model ExplanationPerformance {
  id                     String           @id @default(cuid())
  explanationId          String
  skillId                String
  studentSegment         String           @default("default")
  averageLearningGain    Float            @default(0)
  averageHalfLifeDays    Float            @default(0)
  averageInstructionTime Float            @default(0)
  dle                    Float            @default(0)
  evidenceCount          Int              @default(0)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  explanation            ExplanationRoute @relation(fields: [explanationId], references: [id], onDelete: Cascade)
  skill                  Skill            @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([explanationId, studentSegment])
  @@index([skillId, studentSegment])
}

model StudentRewardBalance {
  id         String   @id @default(cuid())
  userId     String   @unique
  xpTotal    Int      @default(0)
  tokenTotal Int      @default(0)
  streakDays Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RewardTransaction {
  id             String   @id @default(cuid())
  userId         String
  subjectId      String?
  eventName      String
  xpDelta        Int
  tokenDelta     Int
  reason         String
  idempotencyKey String?  @unique
  metadata       Json?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject        Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([eventName, createdAt])
}

model GuessingSafeguardState {
  id               String    @id @default(cuid())
  userId           String    @unique
  rapidWrongStreak Int       @default(0)
  lastWrongAt      DateTime?
  penaltyRemaining Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Event {
  id            String   @id @default(cuid())
  name          String
  actorUserId   String?
  studentUserId String?
  subjectId     String?
  skillId       String?
  itemId        String?
  attemptId     String?
  payload       Json
  createdAt     DateTime @default(now())
  actor         User?    @relation(fields: [actorUserId], references: [id])
  subject       Subject? @relation(fields: [subjectId], references: [id])
  skill         Skill?   @relation(fields: [skillId], references: [id])
  item          Item?    @relation(fields: [itemId], references: [id])
  attempt       Attempt? @relation(fields: [attemptId], references: [id])
}

model ExplanationRoute {
  id                   String            @id @default(cuid())
  skillId              String
  routeType            String
  misconceptionSummary String
  workedExample        String
  guidedPrompt         String
  guidedAnswer         String
  isActive             Boolean           @default(true)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  skill                  Skill                     @relation(fields: [skillId], references: [id])
  steps                  ExplanationStep[]
  explanationPerformance ExplanationPerformance[]

  @@unique([skillId, routeType])
}

model ExplanationStep {
  id                 String            @id @default(cuid())
  explanationRouteId String
  stepOrder          Int
  title              String
  explanation        String
  stepType           String            @default("checkpoint")
  checkpointQuestion String
  checkpointOptions  Json
  checkpointAnswer   String
  alternativeHint    String?
  subtopicCode       String?
  questionType       String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  route              ExplanationRoute  @relation(fields: [explanationRouteId], references: [id], onDelete: Cascade)
  interactions       StepInteraction[]

  @@unique([explanationRouteId, stepOrder])
}

model InteractionType {
  id          String            @id @default(cuid())
  key         String
  version     String
  schema      Json?
  rendererKey String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  steps       StepInteraction[]

  @@unique([key, version])
}

model StepInteraction {
  id                String          @id @default(cuid())
  explanationStepId String
  interactionTypeId String
  sortOrder         Int             @default(1)
  config            Json
  completionRule    Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  step              ExplanationStep @relation(fields: [explanationStepId], references: [id], onDelete: Cascade)
  interactionType   InteractionType @relation(fields: [interactionTypeId], references: [id])

  @@unique([explanationStepId, sortOrder])
}

model DiagnosticSession {
  id               String           @id @default(cuid())
  userId           String
  subjectId        String
  startedAt        DateTime         @default(now())
  completedAt      DateTime?
  status           DiagnosticStatus @default(IN_PROGRESS)
  maxItems         Int              @default(25)
  minItems         Int              @default(12)
  confidenceTarget Float            @default(0.85)
  itemsSeen        Int              @default(0)
  payload          Json             @default("{}")
  user             User             @relation(fields: [userId], references: [id])
  subject          Subject          @relation(fields: [subjectId], references: [id])
  attempts         Attempt[]        @relation("DiagnosticAttempts")
}

model BaselineSession {
  id          String            @id @default(cuid())
  userId      String
  subjectId   String
  startedAt   DateTime          @default(now())
  completedAt DateTime?
  status      BaselineStatus    @default(IN_PROGRESS)
  itemsSeen   Int               @default(0)
  maxItems    Int               @default(24)
  payload     Json              @default("{}")
  user        User              @relation(fields: [userId], references: [id])
  subject     Subject           @relation(fields: [subjectId], references: [id])
  attempts    BaselineAttempt[]

  @@index([userId, subjectId, status])
}

model BaselineAttempt {
  id                String          @id @default(cuid())
  baselineSessionId String
  userId            String
  itemId            String
  skillId           String
  answer            String
  correct           Boolean
  createdAt         DateTime        @default(now())
  baselineSession   BaselineSession @relation(fields: [baselineSessionId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id])
  item              Item            @relation(fields: [itemId], references: [id])
  skill             Skill           @relation(fields: [skillId], references: [id])

  @@unique([baselineSessionId, itemId])
  @@index([baselineSessionId, skillId])
}

model InterventionFlag {
  id         String    @id @default(cuid())
  userId     String
  subjectId  String
  skillId    String
  reason     String
  isResolved Boolean   @default(false)
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  resolvedAt DateTime?
  user       User      @relation(fields: [userId], references: [id])
  subject    Subject   @relation(fields: [subjectId], references: [id])
  skill      Skill     @relation(fields: [skillId], references: [id])

  @@unique([userId, skillId])
}

model TeacherProfile {
  id                String             @id @default(cuid())
  userId            String             @unique
  externalSource    String             @default("anaxi_observe")
  externalTeacherId String
  externalSchoolId  String?
  displayName       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  classrooms        TeacherClassroom[]

  @@unique([externalSource, externalTeacherId])
}

model StudentProfile {
  id                String                @id @default(cuid())
  userId            String                @unique
  externalSource    String                @default("anaxi_observe")
  externalStudentId String
  externalSchoolId  String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments       ClassroomEnrollment[]

  @@unique([externalSource, externalStudentId])
}

model Classroom {
  id               String                @id @default(cuid())
  externalSource   String                @default("anaxi_observe")
  externalClassId  String
  externalSchoolId String?
  name             String
  yearGroup        String?
  subjectSlug      String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  teachers         TeacherClassroom[]
  enrollments      ClassroomEnrollment[]
  liveSessions     LiveSession[]

  @@unique([externalSource, externalClassId])
}

model TeacherClassroom {
  id               String         @id @default(cuid())
  teacherProfileId String
  classroomId      String
  roleLabel        String?
  createdAt        DateTime       @default(now())
  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  classroom        Classroom      @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@unique([teacherProfileId, classroomId])
}

model ClassroomEnrollment {
  id               String          @id @default(cuid())
  classroomId      String
  studentUserId    String
  studentProfileId String?
  createdAt        DateTime        @default(now())
  classroom        Classroom       @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student          User            @relation(fields: [studentUserId], references: [id], onDelete: Cascade)
  studentProfile   StudentProfile? @relation(fields: [studentProfileId], references: [id], onDelete: SetNull)

  @@unique([classroomId, studentUserId])
}

model LiveSession {
  id            String            @id @default(cuid())
  classroomId   String
  teacherUserId String
  subjectId     String
  skillId       String?
  status        LiveSessionStatus @default(LOBBY)
  joinCode      String            @unique
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  classroom     Classroom         @relation(fields: [classroomId], references: [id])
  teacher       User              @relation("TeacherLiveSessions", fields: [teacherUserId], references: [id])
  subject       Subject           @relation(fields: [subjectId], references: [id])
  skill         Skill?            @relation(fields: [skillId], references: [id])
  participants  LiveParticipant[]
  liveAttempts  LiveAttempt[]
}

model LiveParticipant {
  id            String      @id @default(cuid())
  liveSessionId String
  studentUserId String
  joinedAt      DateTime    @default(now())
  isActive      Boolean     @default(true)

  session       LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  student       User        @relation(fields: [studentUserId], references: [id], onDelete: Cascade)

  @@unique([liveSessionId, studentUserId])
}

model LiveAttempt {
  id            String      @id @default(cuid())
  liveSessionId String
  studentUserId String
  itemId        String
  skillId       String
  answer        String
  correct       Boolean
  responseTimeMs Int
  createdAt     DateTime    @default(now())

  session       LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  student       User        @relation(fields: [studentUserId], references: [id], onDelete: Cascade)
  item          Item        @relation(fields: [itemId], references: [id])
  skill         Skill       @relation(fields: [skillId], references: [id])

  @@index([liveSessionId, skillId])
  @@index([liveSessionId, studentUserId])
}
